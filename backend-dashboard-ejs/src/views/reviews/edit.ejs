<div class="mb-6">
  <h2 class="text-2xl font-bold">Edit Review</h2>

  <p class="text-gray-500 text-sm">Update reviews details</p>
</div>

<div class="card max-w-2xl">
  <form method="POST" class="space-y-4">
    <div>
      <label class="block text-sm mb-1"> Guest Name </label>
      <input
        name="guestName"
        value="<%= review.guestName %>"
        required
        class="w-full border p-3 rounded"
      />
    </div>

    <div>
      <label class="block text-sm mb-1"> Rating </label>

      <input
        type="number"
        name="rating"
        min="1"
        max="5"
        required
        value="<%= review.rating %>"
        class="w-full border p-3 rounded"
      />
    </div>

    <div>
      <label class="block text-sm mb-1"> Location </label>
      <input
        name="location"
        value="<%= review.location %>"
        required
        class="w-full border p-3 rounded"
      />
    </div>

    <div>
      <label class="block text-sm mb-1">Comment </label>
      <textarea
        name="comment"
        required
        rows="5"
        class="w-full border p-3 rounded"
      >
     <%= review.comment %>
     </textarea
      >
    </div>

    <div class="flex gap-3 pt-4">
      <button class="btn-primary">Update</button>

      <a href="/admin/reviews" class="px-4 py-2 border rounded"> Cancel </a>
    </div>
  </form>
</div>

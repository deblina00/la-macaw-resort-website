<h2 class="text-xl font-bold mb-4">Edit Review</h2>

<form method="POST" class="bg-white p-6 shadow w-1/2">

<input
name="guestName"
value="<%= review.guestName %>"
required
class="border p-2 w-full mb-3"
>

<input
type="number"
name="rating"
min="1"
max="5"
required
value="<%= review.rating %>"
class="border p-2 w-full mb-3"
>

<input
name="location"
value="<%= review.location %>"
required
class="border p-2 w-full mb-3"
>

<textarea
name="comment"
required
class="border p-2 w-full mb-3"
><%= review.comment %></textarea>

<button class="bg-blue-600 text-white px-4 py-2">
Update
</button>

</form>
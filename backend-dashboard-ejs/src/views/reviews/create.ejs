<h2>Add Review</h2>

<form method="POST">

<input
name="guestName"
placeholder="Guest Name"
class="border p-2 w-full mb-3"
>

<input
type="number"
name="rating"
min="1"
max="5"
placeholder="Rating (1-5)"
class="border p-2 w-full mb-3"
>

<input
name="location"
placeholder="Location (City / Branch)"
class="border p-2 w-full mb-3"
>

<textarea
name="comment"
placeholder="Review Comment"
class="border p-2 w-full mb-3"
></textarea>

<button class="bg-blue-600 text-white px-4 py-2">
Save
</button>

</form>
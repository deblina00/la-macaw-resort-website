<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">
      Guests Reviews
    </h2>

    <p class="text-gray-500 text-sm">
      Manage reviews from your guests
    </p>
  </div>

<a href="/admin/reviews/create"
class="btn-primary">
+ Add Review
</a>
</div>

<!-- Filter -->
<div class="card mb-5">

<form method="GET" class="flex gap-3 items-center">

<select name="rating" class="border p-2 rounded"">

  <option value="">All Ratings</option>
  <option value="5">5 Star</option>
  <option value="4">4 Star</option>
</select>

<button class="btn-secondary">
Filter
</button>

 <a
      href="/admin/reviews"
      class="px-4 py-2 border rounded"
    >
      Reset
    </a>
</form>
</div>

<!-- Rating Table -->

<div class="card overflow-x-auto">

  <table class="w-full text-sm">

    <thead class="bg-gray-100">
    <tr>
      <th class="p-3 text-left">Guest</th>
      <th class="p-3 text-left">Rating</th>
      <th class="p-3 text-left">Comment</th>
      <th class="p-3 text-left">Location</th>
      <th class="p-3 text-center">Action</th>
    </tr>

 </thead>

<tbody>

   <% if(reviews.length === 0){ %>

   <tr>
    <td colspan="5" class="text-center text-gray-500 py-8">
       No reviews found
    </td>
   </tr>

<% } %>

<% reviews.forEach(review => { %>

<tr class="border-b hover:bg-gray-50 transition">

<td class="p-3 font-semibold"><%= review.guestName %></td>

<td class="p-3">
  <%= review.rating %> ⭐
</td>

<td class="p-3 max-w-sm">

  <p class="truncate" title="<%= review.comment %>">
    <%= review.comment %>
  </p>

</td>

<td class="p-3">
  <%= review.location %>
</td>


<!-- Actions -->

<td class="p-3 text-center">

<div class="flex justify-center gap-2">

 <!-- Edit -->

  <a href="/admin/reviews/edit/<%= review._id %>"
     class="px-3 py-1 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition text-xs"
  >
     ✏ Edit
  </a>

  <a href="/admin/reviews/delete/<%= review._id %>"
     onclick="return confirm('Delete this review?')"
     class="px-3 py-1 bg-red-500 text-white rounded-lg hover:bg-red-600 transition text-xs"

  >
    🗑 Delete
  </a>
  </div>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

<!-- Pagination -->

<div class="flex justify-center mt-6">

  <div class="flex gap-2">

  <% if (currentPage > 1) { %>
    <a href="?page=<%= currentPage - 1 %>"
       class="px-3 py-1 border rounded hover:bg-gray-200">
       Previous
    </a>
  <% } %>

  <% for (let i = 1; i <= totalPages; i++) { %>
    <a href="?page=<%= i %>"
       class="px-3 py-1 border mx-1 
       <%= currentPage === i ? 'bg-emerald-600 text-white' : 'hover:bg-gray-200' %>">
       <%= i %>
    </a>
  <% } %>

  <% if (currentPage < totalPages) { %>
    <a href="?page=<%= currentPage + 1 %>"
        class="px-3 py-1 border rounded hover:bg-gray-200">
       Next
    </a>
  <% } %>
  </div>

</div>
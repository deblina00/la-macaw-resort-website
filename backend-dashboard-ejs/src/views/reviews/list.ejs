<h2 class="text-xl font-bold mb-4">Reviews</h2>

<a href="/admin/reviews/create"
class="bg-green-600 text-white px-4 py-2 mb-4 inline-block">
Add Review
</a>

<form method="GET" class="mb-4">

<select name="rating" class="border px-3 py-2">
  <option value="">All Ratings</option>
  <option value="5">5 Star</option>
  <option value="4">4 Star</option>
</select>

<button class="bg-blue-600 text-white px-4 py-2">
Filter
</button>

</form>

<table class="w-full bg-white shadow">

<tr class="bg-gray-200">
<th class="p-2">Guest</th>
<th class="p-2">Rating</th>
<th class="p-2">Comment</th>
<th class="p-2">Location</th>
<th class="p-2">Action</th>
</tr>

<% reviews.forEach(review => { %>

<tr class="border-t">

<td class="p-2"><%= review.guestName %></td>

<td class="p-2"><%= review.rating %> ⭐</td>

<td class="p-2"><%= review.comment %></td>

<td class="p-2"><%= review.location %></td>

<td class="p-2">

<a href="/admin/reviews/edit/<%= review._id %>"
class="text-blue-500">
Edit
</a>

<a href="/admin/reviews/delete/<%= review._id %>"
class="text-red-500 ml-3">
Delete
</a>

</td>

</tr>

<% }) %>

</table>

<!-- Pagination -->

<div class="mt-6 flex justify-center">

  <% if (currentPage > 1) { %>
    <a href="?page=<%= currentPage - 1 %>"
       class="px-3 py-1 border mx-1">
       Previous
    </a>
  <% } %>

  <% for (let i = 1; i <= totalPages; i++) { %>
    <a href="?page=<%= i %>"
       class="px-3 py-1 border mx-1 
       <%= currentPage === i ? 'bg-black text-white' : '' %>">
       <%= i %>
    </a>
  <% } %>

  <% if (currentPage < totalPages) { %>
    <a href="?page=<%= currentPage + 1 %>"
       class="px-3 py-1 border mx-1">
       Next
    </a>
  <% } %>

</div>
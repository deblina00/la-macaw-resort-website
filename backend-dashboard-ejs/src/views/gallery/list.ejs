<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">
      Gallery
    </h2>

    <p class="text-gray-500 text-sm">
      Manage resort images and media
    </p>
  </div>

  <a
    href="/admin/gallery/upload"
    class="btn-primary"
  >
    + Upload Image
  </a>

</div>


<!-- Filter -->

<div class="card mb-5">

  <form method="GET" class="flex gap-3 items-center">

    <select
      name="category"
      class="border p-2 rounded"
    >
      <option value="">All Categories</option>

      <option value="rooms">Rooms</option>
      <option value="banquets">Banquets</option>
      <option value="events">Events</option>
      <option value="tajpur">Tajpur</option>
      <option value="joypur">Joypur</option>
      <option value="purulia">Purulia</option>

    </select>

    <button class="btn-primary">
      Filter
    </button>

    <a
      href="/admin/gallery"
      class="px-4 py-2 border rounded"
    >
      Reset
    </a>

  </form>

</div>


<!-- Gallery Grid -->

<div class="card">

  <% if(images.length === 0){ %>

    <div class="text-center py-10 text-gray-500">
      No images found
    </div>

  <% } else { %>

  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-5">

    <% images.forEach(gallery => { %>

      <div class="border rounded-lg overflow-hidden shadow-sm">

        <img
          src="<%= gallery.image %>"
          class="h-40 w-full object-cover"
        >

        <div class="p-3">

          <p class="text-sm font-semibold truncate">
            <%= gallery.title || "Untitled" %>
          </p>

          <p class="text-xs text-gray-500 mb-2">
            <%= gallery.category %>
          </p>

          <a
            href="/admin/gallery/delete/<%= gallery._id %>"
            onclick="return confirm('Delete this image?')"
            class="text-red-600 text-sm hover:underline"
          >
            Delete
          </a>

        </div>

      </div>

    <% }) %>

  </div>

  <% } %>

</div>


<!-- Pagination -->

<div class="flex justify-center mt-6">

  <div class="flex gap-2">

    <% if (currentPage > 1) { %>

      <a
        href="?page=<%= currentPage - 1 %>"
        class="px-3 py-1 border rounded hover:bg-gray-200"
      >
        Previous
      </a>

    <% } %>


    <% for (let i = 1; i <= totalPages; i++) { %>

      <a
        href="?page=<%= i %>"
        class="px-3 py-1 border rounded
        <%= currentPage === i ? 'bg-emerald-600 text-white' : 'hover:bg-gray-200' %>"
      >
        <%= i %>
      </a>

    <% } %>


    <% if (currentPage < totalPages) { %>

      <a
        href="?page=<%= currentPage + 1 %>"
        class="px-3 py-1 border rounded hover:bg-gray-200"
      >
        Next
      </a>

    <% } %>

  </div>

</div>
<h2 class="text-xl font-bold mb-4">Gallery</h2>

<a href="/admin/gallery/upload"
class="bg-green-600 text-white px-4 py-2 mb-4 inline-block">
Upload Image
</a>

<form method="GET" class="mb-4">

<select name="category" class="border px-3 py-2">
  <option value="">All</option>
  <option value="rooms">Rooms</option>
  <option value="banquets">Banquets</option>
  <option value="events">Events</option>
</select>

<button class="bg-blue-600 text-white px-4 py-2">
Filter
</button>

</form>

<table class="w-full bg-white shadow">

<tr class="bg-gray-200">
<th class="p-2">Image</th>
<th class="p-2">Category</th>
<th class="p-2">Action</th>
</tr>

<% images.forEach(gallery => { %>

<tr class="border-t">

<td class="p-2">
<img src="<%= gallery.image %>"
class="w-20 rounded">
</td>

<td class="p-2">
<%= gallery.category %>
</td>

<td class="p-2">
<a href="/admin/gallery/delete/<%= gallery._id %>"
class="text-red-500">
Delete
</a>
</td>

</tr>

<% }) %>

</table>

<!-- Pagination -->

<div class="mt-6 flex justify-center">

  <% if (currentPage > 1) { %>
    <a href="?page=<%= currentPage - 1 %>"
       class="px-3 py-1 border mx-1">
       Previous
    </a>
  <% } %>

  <% for (let i = 1; i <= totalPages; i++) { %>
    <a href="?page=<%= i %>"
       class="px-3 py-1 border mx-1 
       <%= currentPage === i ? 'bg-black text-white' : '' %>">
       <%= i %>
    </a>
  <% } %>

  <% if (currentPage < totalPages) { %>
    <a href="?page=<%= currentPage + 1 %>"
       class="px-3 py-1 border mx-1">
       Next
    </a>
  <% } %>

</div>
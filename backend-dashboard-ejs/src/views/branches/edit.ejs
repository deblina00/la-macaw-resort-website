<h2 class="text-xl font-bold mb-4">Edit Branch</h2>

<form method="POST" enctype="multipart/form-data">

<input
name="name"
value="<%= branch.name %>"
class="border p-2 mb-3 w-full"
required
>

<input
name="location"
value="<%= branch.location %>"
class="border p-2 mb-3 w-full"
required
>

<textarea
name="description"
class="border p-2 mb-3 w-full"
><%= branch.description %></textarea>

<input
name="amenities"
value="<%= branch.amenities?.join(', ') %>"
class="border p-2 mb-3 w-full"
>

<input
type="file"
name="images"
multiple
class="border p-2 mb-3 w-full"
>

<button class="bg-blue-600 text-white px-4 py-2">
Update
</button>

</form>
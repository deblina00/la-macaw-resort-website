<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">Branches</h2>
    <p class="text-gray-500 text-sm">
      Manage resort properties and locations
    </p>
  </div>

  <a href="/admin/branches/create" class="btn-primary">
    + Add Branch
  </a>

</div>


<div class="card">

  <table class="table">

    <thead>
      <tr>
        <th>Branch</th>
        <th>Location</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>

    <tbody>

      <% if(branches.length === 0){ %>

        <tr>
          <td colspan="3" class="text-center py-6 text-gray-500">
            No branches available
          </td>
        </tr>

      <% } %>

      <% branches.forEach(branch => { %>

      <tr>

        <td class="font-semibold">
          <%= branch.name %>
        </td>

        <td class="text-gray-600">
          <%= branch.location %>
        </td>

        <td class="text-center space-x-4">

          <a
            href="/admin/branches/edit/<%= branch._id %>"
            class="text-blue-600 hover:underline"
          >
            Edit
          </a>

          <a
            href="/admin/branches/delete/<%= branch._id %>"
            onclick="return confirm('Delete this branch?')"
            class="text-red-600 hover:underline"
          >
            Delete
          </a>

        </td>

      </tr>

      <% }) %>

    </tbody>

  </table>

</div>
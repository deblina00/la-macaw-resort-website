<div class="mb-6">

  <h2 class="text-2xl font-bold">
    Create Branch
  </h2>

  <p class="text-gray-500 text-sm">
    Add a new resort property
  </p>

</div>


<div class="card max-w-3xl">

<form method="POST" enctype="multipart/form-data" class="space-y-4">

  <div class="grid grid-cols-2 gap-4">
  <div>
    <label class="block text-sm mb-1">
      Branch Name
    </label>

    <input
      name="name"
      class="w-full border p-3 rounded"
      required
    >
  </div>


  <div>
    <label class="block text-sm mb-1">
      Location
    </label>

    <input
      name="location"
      class="w-full border p-3 rounded"
      required
      placeholder="Purulia, West Bengal"
    >
  </div>
</div>

  <div>
    <label class="block text-sm mb-1">
      Description
    </label>

    <textarea
      name="description"
      class="w-full border p-3 rounded h-32"
    ></textarea>
  </div>


  <div>
    <label class="block text-sm mb-1">
      Amenities (comma separated)
    </label>

    <input
      name="amenities"
      class="w-full border p-3 rounded"
      placeholder="Swimming Pool, Restaurant, Parking"
    >
  </div>


  <div>
    <label class="block text-sm mb-1">
      Branch Images
    </label>

    <input
      type="file"
      name="images"
      multiple
      class="w-full border p-2 rounded"
    >
  </div>


  <div class="flex gap-3 pt-4">

    <button class="btn-primary">
      Save Branch
    </button>

    <a href="/admin/branches" class="px-4 py-2 border rounded">
      Cancel
    </a>

  </div>

</form>

</div>
<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">
      Events Management
    </h2>

    <p class="text-gray-500 text-sm">
      Manage weddings, corporate events, and private parties
    </p>
  </div>

  <a
    href="/admin/events/create"
    class="btn-primary"
  >
    + Create Event
  </a>

</div>


<!-- Table Card -->

<div class="card overflow-x-auto">

  <table class="w-full text-sm">

    <thead class="bg-gray-100">
      <tr>
        <th class="p-3 text-left">Title</th>
        <th class="p-3 text-left">Category</th>
        <th class="p-3 text-left">Images</th>
        <th class="p-3 text-center">Actions</th>
      </tr>
    </thead>

    <tbody>

      <% if(events.length === 0){ %>

        <tr>
          <td colspan="5" class="text-center text-gray-500 py-8">
            No events available
          </td>
        </tr>

      <% } %>


      <% events.forEach(event => { %>

        <tr class="border-b hover:bg-gray-50 transition">

        <!-- Event Title -->

        <td class="p-3 font-semibold">
            <%= event.title %>
          </td>

          <td class="p-3">

            <span class="
              px-2 py-1 rounded text-xs
              <%= event.category === 'wedding'
                ? 'bg-pink-100 text-pink-600'
                : event.category === 'corporate'
                ? 'bg-blue-100 text-blue-600'
                : 'bg-green-100 text-green-600'
              %>
            ">
              <%= event.category %>
            </span>

          </td>

          <td class="p-3">

            <% if(event.images && event.images.length){ %>

              <% event.images.slice(0,3).forEach(img => { %>

                <img
                  src="<%= img %>"
                  class="w-16 h-16 object-cover inline-block mr-2 rounded"
                >

              <% }) %>

              <% if(event.images.length > 3){ %>
                <span class="text-gray-500 text-xs">
                  +<%= event.images.length - 3 %> more
                </span>
              <% } %>

            <% } else { %>

              <span class="text-gray-400">
                No images
              </span>

            <% } %>

          </td>

        <!-- Actions -->

        <td class="p-3 text-center">

          <div class="flex justify-center gap-2">

            <!-- Edit -->

            <a
              href="/admin/events/edit/<%= event._id %>"
              class="px-3 py-1 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition text-xs"
            >
             ✏ Edit
            </a>

            <a
              href="/admin/events/delete/<%= event._id %>"
              onclick="return confirm('Delete this event?')"
              class="px-3 py-1 bg-red-500 text-white rounded-lg hover:bg-red-600 transition text-xs"
            >
              Delete
            </a>
            </div>

          </td>

        </tr>

      <% }) %>

    </tbody>

  </table>

</div>



<h2>Edit Event</h2>

<form method="POST" enctype="multipart/form-data">

<input
name="title"
value="<%= event.title %>"
class="border p-2 w-full mb-3"
>

<textarea
name="description"
class="border p-2 w-full mb-3"
><%= event.description %></textarea>

<select
name="category"
class="border p-2 w-full mb-3"
>

<option value="wedding"
<%= event.category === "wedding" ? "selected" : "" %>>
Wedding
</option>

<option value="corporate"
<%= event.category === "corporate" ? "selected" : "" %>>
Corporate
</option>

<option value="private"
<%= event.category === "private" ? "selected" : "" %>>
Private
</option>

</select>

<p class="mb-2">Current Images</p>

<% event.images.forEach(img => { %>

<img src="<%= img %>" class="w-24 inline-block mr-2 mb-2 rounded">

<% }) %>

<input
type="file"
name="images"
multiple
class="border p-2 w-full mb-3"
>

<button class="bg-blue-600 text-white px-4 py-2">
Update
</button>

</form>
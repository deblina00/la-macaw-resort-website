<div class="mb-6">

  <h2 class="text-2xl font-bold">
    Create Banquet
  </h2>

  <p class="text-gray-500 text-sm">
    Add a new banquet hall or lawn
  </p>

</div>


<div class="card max-w-2xl">

<form method="POST" enctype="multipart/form-data" class="space-y-4">

  <div>

    <label class="block text-sm mb-1">
      Banquet Title
    </label>

    <input
      name="title"
      required
      class="w-full border p-3 rounded"
      placeholder="Royal Banquet Hall"
    />

  </div>


  <div>

    <label class="block text-sm mb-1">
      Branch
    </label>

    <select
      name="branchId"
      class="w-full border p-3 rounded"
      required
    >

      <% branches.forEach(branch => { %>

        <option value="<%= branch._id %>">
          <%= branch.name %>
        </option>

      <% }) %>

    </select>

  </div>


  <div class="grid md:grid-cols-2 gap-4">

    <div>

      <label class="block text-sm mb-1">
        Total Area (sqft)
      </label>

      <input
        name="totalArea"
        class="w-full border p-3 rounded"
        placeholder="2000"
      />

    </div>

    <div>

      <label class="block text-sm mb-1">
        Capacity
      </label>

      <input
        name="capacity"
        class="w-full border p-3 rounded"
        placeholder="300"
      />

    </div>

  </div>


  <div>

    <label class="block text-sm mb-1">
      Type
    </label>

    <select
      name="type"
      class="w-full border p-3 rounded"
    >

      <option value="Hall">Hall</option>
      <option value="Lawn">Lawn</option>

    </select>

  </div>


  <div>

    <label class="block text-sm mb-1">
      Features
    </label>

    <input
      name="features"
      placeholder="AC, Stage, Lighting, Parking"
      class="w-full border p-3 rounded"
    />

  </div>


  <div>

    <label class="block text-sm mb-1">
      Upload Images
    </label>

    <input
      type="file"
      name="images"
      multiple
      class="border p-2 rounded w-full"
    />

  </div>


  <div class="flex gap-3 pt-4">

    <button class="btn-primary">
      Save Banquet
    </button>

    <a
      href="/admin/banquets"
      class="px-4 py-2 border rounded"
    >
      Cancel
    </a>

  </div>

</form>

</div>
<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">
      Banquet Management
    </h2>

    <p class="text-gray-500 text-sm">
      Manage resort banquet halls and lawns
    </p>
  </div>

  <a
    href="/admin/banquets/create"
    class="btn-primary"
  >
    + Add Banquet
  </a>

</div>


<!-- Table Card -->

<div class="card overflow-x-auto">

  <table class="w-full text-sm">

    <thead class="bg-gray-100">
      <tr>
        <th class="p-3 text-left">Title</th> 
        <th class="p-3 text-left">Image</th>
        <th class="p-3 text-left">Branch</th>
        <th class="p-3 text-left">Area</th>
        <th class="p-3 text-left">Capacity</th>
        <th class="p-3 text-left">Type</th>
        <th class="p-3 text-center">Actions</th>
      </tr>
    </thead>

   <tbody>

  <% if(banquets.length === 0){ %>
    <tr>
      <td colspan="7" class="text-center py-8 text-gray-500">
        No banquets found
      </td>
    </tr>
  <% } %>

  <% banquets.forEach(b => { %>

    <tr class="border-b hover:bg-gray-50 transition">

      <!-- Title -->
      <td class="p-3 font-semibold">
        <%= b.title %>
        <div class="text-xs text-gray-400">
          <%= b.slug %>
        </div>
      </td>

      <!-- Image -->
      <td class="p-3">
        <% if(b.images && b.images.length > 0){ %>
          <img
            src="<%= b.images[0] %>"
            class="w-16 h-12 object-cover rounded"
          />
        <% } else { %>
          <span class="text-gray-400 text-xs">No Image</span>
        <% } %>
      </td>

      <!-- Branch -->
      <td class="p-3">
        <%= b.branchId?.name || '-' %>
      </td>

      <!-- Area -->
      <td class="p-3">
        <%= b.totalArea %> sqft
      </td>

      <!-- Capacity -->
      <td class="p-3">
        <%= b.seatingCapacity?.max || b.seatingCapacity?.floating || '-' %>
      </td>

      <!-- Type -->
      <td class="p-3">
        <span class="
          px-2 py-1 rounded text-xs
          <%= b.type === 'Hall'
            ? 'bg-blue-100 text-blue-600'
            : 'bg-green-100 text-green-600' %>
        ">
          <%= b.type %>
        </span>
      </td>

      <!-- Actions -->
      <td class="p-3 text-center">
        <div class="flex justify-center gap-2">

          <a
            href="/admin/banquets/edit/<%= b._id %>"
            class="px-3 py-1 bg-blue-500 text-white rounded text-xs"
          >
            ✏ Edit
          </a>

          <a
            href="/admin/banquets/delete/<%= b._id %>"
            onclick="return confirm('Delete this banquet?')"
            class="px-3 py-1 bg-red-500 text-white rounded text-xs"
          >
            🗑 Delete
          </a>

        </div>
      </td>

    </tr>

  <% }) %>

</tbody>

  </table>

</div>

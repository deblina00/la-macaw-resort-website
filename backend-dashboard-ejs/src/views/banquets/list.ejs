<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">
      Banquet Management
    </h2>

    <p class="text-gray-500 text-sm">
      Manage resort banquet halls and lawns
    </p>
  </div>

  <a
    href="/admin/banquets/create"
    class="btn-primary"
  >
    + Add Banquet
  </a>

</div>


<div class="card">

  <table class="w-full text-sm">

    <thead class="bg-gray-100">
      <tr>
        <th class="p-3 text-left">Title</th>
        <th class="p-3 text-left">Branch</th>
        <th class="p-3 text-left">Area</th>
        <th class="p-3 text-left">Capacity</th>
        <th class="p-3 text-left">Type</th>
        <th class="p-3 text-center">Actions</th>
      </tr>
    </thead>

    <tbody>

      <% if(banquets.length === 0){ %>

        <tr>
          <td colspan="6" class="text-center p-6 text-gray-500">
            No banquets found
          </td>
        </tr>

      <% } %>

      <% banquets.forEach(b => { %>

        <tr class="border-t">

          <td class="p-3 font-medium">
            <%= b.title %>
          </td>

          <td class="p-3">
            <%= b.branchId?.name || '-' %>
          </td>

          <td class="p-3">
            <%= b.totalArea %> sqft
          </td>

          <td class="p-3">
            <%= b.capacity %>
          </td>

          <td class="p-3">

            <span class="
              px-2 py-1 rounded text-xs
              <%= b.type === 'Hall'
                ? 'bg-blue-100 text-blue-600'
                : 'bg-green-100 text-green-600' %>
            ">
              <%= b.type %>
            </span>

          </td>

          <td class="p-3 text-center space-x-3">

            <a
              href="/admin/banquets/edit/<%= b._id %>"
              class="text-blue-600 hover:underline"
            >
              Edit
            </a>

            <a
              href="/admin/banquets/delete/<%= b._id %>"
              onclick="return confirm('Delete this banquet?')"
              class="text-red-600 hover:underline"
            >
              Delete
            </a>

          </td>

        </tr>

      <% }) %>

    </tbody>

  </table>

</div>

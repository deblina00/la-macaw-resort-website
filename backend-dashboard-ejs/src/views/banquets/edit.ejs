<div class="mb-6">

  <h2 class="text-2xl font-bold">
    Edit Banquet
  </h2>

  <p class="text-gray-500 text-sm">
    Update banquet details
  </p>

</div>


<div class="card max-w-2xl">

<form method="POST" enctype="multipart/form-data" class="space-y-4">

  <div>

    <label class="block text-sm mb-1">
      Banquet Title
    </label>

    <input
      name="title"
      value="<%= banquet.title %>"
      class="w-full border p-3 rounded"
    />

  </div>


  <div>

    <label class="block text-sm mb-1">
      Branch
    </label>

    <select
      name="branchId"
      class="w-full border p-3 rounded"
    >

      <% branches.forEach(branch => { %>

        <option
          value="<%= branch._id %>"
          <%= banquet.branchId == branch._id ? "selected" : "" %>
        >
          <%= branch.name %>
        </option>

      <% }) %>

    </select>

  </div>


  <div class="grid md:grid-cols-2 gap-4">

    <input
      name="totalArea"
      value="<%= banquet.totalArea %>"
      class="border p-3 rounded"
      placeholder="Area"
    />

    <input
      name="capacity"
      value="<%= banquet.capacity %>"
      class="border p-3 rounded"
      placeholder="Capacity"
    />

  </div>


  <div>

    <select name="type" class="w-full border p-3 rounded">

      <option
        value="Hall"
        <%= banquet.type === "Hall" ? "selected" : "" %>
      >
        Hall
      </option>

      <option
        value="Lawn"
        <%= banquet.type === "Lawn" ? "selected" : "" %>
      >
        Lawn
      </option>

    </select>

  </div>


  <div>

    <input
      name="features"
      value="<%= banquet.features?.join(', ') %>"
      class="w-full border p-3 rounded"
      placeholder="Features"
    />

  </div>


  <div>

    <label class="text-sm">
      Upload New Images
    </label>

    <input
      type="file"
      name="images"
      multiple
      class="border p-2 rounded w-full"
    />

  </div>


  <div class="flex gap-3 pt-4">

    <button class="btn-primary">
      Update Banquet
    </button>

    <a
      href="/admin/banquets"
      class="px-4 py-2 border rounded"
    >
      Cancel
    </a>

  </div>

</form>

</div>
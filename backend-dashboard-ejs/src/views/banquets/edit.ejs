<h2>Edit Banquet</h2>

<form method="POST" enctype="multipart/form-data">

<input
name="title"
value="<%= banquet.title %>"
class="border p-2 w-full mb-3"
>

<select name="branchId" class="border p-2 w-full mb-3">

<% branches.forEach(branch => { %>

<option value="<%= branch._id %>"
<%= banquet.branchId == branch._id ? "selected" : "" %>>

<%= branch.name %>

</option>

<% }) %>

</select>

<input
name="capacity"
value="<%= banquet.capacity %>"
class="border p-2 w-full mb-3"
>

<select name="type" class="border p-2 w-full mb-3">

<option value="Hall"
<%= banquet.type === "Hall" ? "selected" : "" %>>
Hall
</option>

<option value="Lawn"
<%= banquet.type === "Lawn" ? "selected" : "" %>>
Lawn
</option>

</select>

<input
name="features"
value="<%= banquet.features?.join(', ') %>"
class="border p-2 w-full mb-3"
>

<input type="file" name="images" multiple
class="border p-2 w-full mb-3">

<button class="bg-blue-600 text-white px-4 py-2">
Update
</button>

</form>
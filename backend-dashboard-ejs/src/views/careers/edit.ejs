<h2>Edit Job</h2>

<% if (typeof error !== "undefined") { %>
<p class="text-red-500"><%= error %></p>
<% } %>

<form method="POST">
  <input name="title" value="<%= job.title %>" required class="border p-2 w-full" />
  <input name="location" value="<%= job.location %>" class="border p-2 w-full" />

  <textarea name="description" class="border p-2 w-full">
<%= job.description %>
</textarea>

  <button class="bg-black text-white px-4 py-2 mt-3">Update</button>
</form>
<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">
      Careers Management
    </h2>

    <p class="text-gray-500 text-sm">
      Create and manage job openings
    </p>
  </div>

  <a
    href="/admin/careers/applications"
    class="btn-primary"
  >
    View Applications
  </a>

</div>


<!-- Error -->

<% if (typeof error !== "undefined") { %>
  <div class="bg-red-100 text-red-600 p-3 rounded mb-4">
    <%= error %>
  </div>
<% } %>


<!-- Create Job Card -->

<div class="card mb-6">

  <h3 class="text-lg font-semibold mb-4">
    Create New Job
  </h3>

  <form
    action="/admin/careers/create"
    method="POST"
    class="grid md:grid-cols-2 gap-4"
  >

    <input
      name="title"
      placeholder="Job Title"
      required
      class="border p-3 rounded"
    />

    <input
      name="location"
      placeholder="Location"
      class="border p-3 rounded"
    />

    <input
      name="department"
      placeholder="Department"
      class="border p-3 rounded"
    />

    <select
      name="status"
      class="border p-3 rounded"
    >
      <option value="active">Active</option>
      <option value="closed">Closed</option>
    </select>

    <textarea
      name="description"
      placeholder="Job Description"
      class="border p-3 rounded md:col-span-2"
    ></textarea>

    <button class="btn-primary md:col-span-2">
      Create Job
    </button>

  </form>

</div>


<!-- Jobs Table -->

<div class="card">

  <h3 class="text-lg font-semibold mb-4">
    Job Listings
  </h3>

  <table class="w-full text-sm">

    <thead class="bg-gray-100">
      <tr>
        <th class="p-3 text-left">Title</th>
        <th class="p-3 text-left">Location</th>
        <th class="p-3 text-left">Department</th>
        <th class="p-3 text-left">Status</th>
        <th class="p-3 text-center">Actions</th>
      </tr>
    </thead>

    <tbody>

      <% jobs.forEach(job => { %>

        <tr class="border-t">

          <td class="p-3 font-medium">
            <%= job.title %>
          </td>

          <td class="p-3">
            <%= job.location || "-" %>
          </td>

          <td class="p-3">
            <%= job.department || "-" %>
          </td>

          <td class="p-3">

            <span class="
              px-2 py-1 text-xs rounded
              <%= job.status === 'active' ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600' %>
            ">
              <%= job.status %>
            </span>

          </td>

          <td class="p-3 text-center space-x-3">

            <a
              href="/admin/careers/edit/<%= job._id %>"
              class="text-blue-600 hover:underline"
            >
              Edit
            </a>

            <a
              href="/admin/careers/delete/<%= job._id %>"
              onclick="return confirm('Delete this job?')"
              class="text-red-600 hover:underline"
            >
              Delete
            </a>

            <a
              href="/admin/careers/toggle/<%= job._id %>"
              class="text-gray-700 hover:underline"
            >
              Toggle
            </a>

          </td>

        </tr>

      <% }) %>

    </tbody>

  </table>

</div>
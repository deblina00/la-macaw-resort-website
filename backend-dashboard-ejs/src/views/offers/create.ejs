

<div class="mb-6">

  <h2 class="text-2xl font-bold">
    Create Offer
  </h2>

  <p class="text-gray-500 text-sm">
    Add new promotional offer
  </p>

</div>


<div class="card max-w-3xl">

<form method="POST" enctype="multipart/form-data" class="space-y-6">

  <!-- TITLE -->

  <div>

    <label class="block text-sm mb-1">
      Offer Title
    </label>

    <input
      name="title"
      class="w-full border p-3 rounded"
      placeholder="Summer Wedding Offer"
    />

  </div>


  <!-- POPUP -->

  <div>

    <label class="block text-sm mb-1">
      Popup Banner
    </label>

    <input
      type="file"
      name="popupImage"
      class="border p-2 rounded w-full"
    />

  </div>


  <!-- BRANCH OFFERS -->

  <h3 class="font-semibold">
    Branch Offers
  </h3>


  <% ["Tajpur","Joypur","Purulia"].forEach((branch, i) => { %>

    <div class="border rounded p-4">

      <h4 class="font-semibold mb-3">
        <%= branch.name %>
      </h4>

      <input
        type="hidden"
        name="branchOffers[<%= i %>][branch]"
        value="<%= branch.name %>"
      >

      <div class="grid md:grid-cols-2 gap-4">

        <input
          name="branchOffers[<%= i %>][price]"
          placeholder="Price"
          class="border p-3 rounded"
        >

        <input
          type="file"
          name="branchImages"
          class="border p-3 rounded"
        >

      </div>

      <textarea
        name="branchOffers[<%= i %>][details]"
        placeholder="Offer Details"
        class="border p-3 rounded w-full mt-3"
      ></textarea>


      <div class="grid md:grid-cols-2 gap-4 mt-3">

        <div>

          <label class="text-sm">From</label>

          <input
            type="date"
            name="branchOffers[<%= i %>][validityFrom]"
            class="border p-3 rounded w-full"
          >

        </div>

        <div>

          <label class="text-sm">To</label>

          <input
            type="date"
            name="branchOffers[<%= i %>][validityTo]"
            class="border p-3 rounded w-full"
          >

        </div>

      </div>

    </div>

  <% }) %>


  <button class="btn-primary">
    Save Offer
  </button>

</form>

</div>
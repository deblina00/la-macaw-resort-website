<h2>Create Offer</h2>

<form method="POST" enctype="multipart/form-data">

  <input name="title" placeholder="Offer Title"
  class="border p-2 w-full mb-3">

  <label>Popup Banner</label>
  <input type="file" name="popupImage"
  class="border p-2 w-full mb-4">

  <h3 class="font-bold mb-2">Branch Offers</h3>

  <% ["Tajpur","Joypur","Purulia"].forEach((branch, i) => { %>

    <div class="border p-4 mb-4">

      <h4 class="font-semibold"><%= branch %></h4>

      <input type="hidden" name="branchOffers[<%= i %>][branch]" value="<%= branch %>">

      <input name="branchOffers[<%= i %>][price]"
      placeholder="Price"
      class="border p-2 w-full mb-2">

      <textarea name="branchOffers[<%= i %>][details]"
      placeholder="Details"
      class="border p-2 w-full mb-2"></textarea>

      <label>From</label>
      <input type="date"
      name="branchOffers[<%= i %>][validityFrom]"
      class="border p-2 w-full mb-2">

      <label>To</label>
      <input type="date"
      name="branchOffers[<%= i %>][validityTo]"
      class="border p-2 w-full mb-2">

      <label>Banner Image</label>
      <input type="file"
      name="branchImages"
      class="border p-2 w-full">

    </div>

  <% }) %>

  <button class="bg-blue-600 text-white px-4 py-2">
    Save
  </button>

</form>
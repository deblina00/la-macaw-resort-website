<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">
      Offers Management
    </h2>

    <p class="text-gray-500 text-sm">
      Manage resort offers and promotions
    </p>
  </div>

  <a href="/admin/offers/create" class="btn-primary">
    + Add Offer
  </a>

</div>


<div class="card overflow-x-auto">

<table class="w-full text-sm">

<thead class="bg-gray-100">

<tr>
  <th class="p-3 text-left">Offer</th>
  <th class="p-3 text-left">Popup</th>
  <th class="p-3 text-left">Branches</th>
  <th class="p-3 text-left">Validity</th>
  <th class="p-3 text-center">Actions</th>
</tr>

</thead>

<tbody>

<% if(offers.length === 0){ %>

<tr>
<td colspan="5" class="text-center py-8 text-gray-500">
No offers available
</td>
</tr>

<% } %>


<% offers.forEach(o => { %>

<tr class="border-b hover:bg-gray-50 transition">

<td class="p-3 font-semibold">
<%= o.title %>
</td>


<td class="p-3">

<% if(o.popupImage){ %>

<img
src="<%= o.popupImage %>"
class="w-20 h-12 object-cover rounded shadow"
/>

<% } else { %>

<span class="text-gray-400 text-xs">
No Image
</span>

<% } %>

</td>


<td class="p-3">

<% o.branchOffers.forEach(b => { %>

<div class="text-xs bg-gray-100 px-2 py-1 rounded mb-1 inline-block">
<%= b.branch %> - ₹<%= b.price %>
</div>

<% }) %>

</td>


<td class="p-3 text-xs text-gray-600">

<% if(o.branchOffers.length){ %>

<%= new Date(o.branchOffers[0]?.validity?.from).toDateString() %>
-
<%= new Date(o.branchOffers[0]?.validity?.to).toDateString() %>

<% } else { %>
-
<% } %>

</td>


<td class="p-3 text-center">

<div class="flex justify-center gap-2">

<a
href="/admin/offers/edit/<%= o._id %>"
class="px-3 py-1 bg-blue-500 text-white rounded-lg text-xs hover:bg-blue-600"
>
✏ Edit
</a>

<a
href="/admin/offers/delete/<%= o._id %>"
onclick="return confirm('Delete this offer?')"
class="px-3 py-1 bg-red-500 text-white rounded-lg text-xs hover:bg-red-600"
>
🗑 Delete
</a>

</div>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>
<div class="mb-6">

  <h2 class="text-2xl font-bold">
    Edit Offer
  </h2>

  <p class="text-gray-500 text-sm">
    Update promotional offer
  </p>

</div>


<div class="card max-w-3xl">

<form method="POST" enctype="multipart/form-data" class="space-y-6">

  <!-- TITLE -->

  <input
    name="title"
    value="<%= offer.title %>"
    class="w-full border p-3 rounded"
  >


  <!-- POPUP -->

  <div>

    <label class="font-semibold">
      Current Popup Banner
    </label>

    <% if (offer.popupImage) { %>

      <img
        src="<%= offer.popupImage %>"
        class="w-64 mt-2 rounded"
      >

    <% } %>

    <input
      type="file"
      name="popupImage"
      class="border p-3 rounded w-full mt-3"
    >

  </div>


  <!-- BRANCH OFFERS -->

  <h3 class="font-semibold">
    Branch Offers
  </h3>


  <% offer.branchOffers.forEach((b, i) => { %>

    <div class="border rounded p-4">

      <h4 class="font-semibold mb-3">
        <%= b.branch %>
      </h4>

      <input
        type="hidden"
        name="branchOffers[<%= i %>][branch]"
        value="<%= b.branch %>"
      >

      <input
        name="branchOffers[<%= i %>][price]"
        value="<%= b.price %>"
        class="border p-3 rounded w-full mb-2"
      >

      <textarea
        name="branchOffers[<%= i %>][details]"
        class="border p-3 rounded w-full mb-2"
      ><%= b.details %></textarea>


      <div class="grid md:grid-cols-2 gap-4">

        <input
          type="date"
          name="branchOffers[<%= i %>][validityFrom]"
          value="<%= b.validity?.from?.toISOString().substring(0,10) %>"
          class="border p-3 rounded"
        >

        <input
          type="date"
          name="branchOffers[<%= i %>][validityTo]"
          value="<%= b.validity?.to?.toISOString().substring(0,10) %>"
          class="border p-3 rounded"
        >

      </div>


      <% if (b.bannerImage) { %>

        <img
          src="<%= b.bannerImage %>"
          class="w-48 mt-3 rounded"
        >

      <% } %>

      <input
        type="file"
        name="branchImages"
        class="border p-3 rounded w-full mt-3"
      >

    </div>

  <% }) %>


  <button class="btn-primary">
    Update Offer
  </button>

</form>

</div>
<div class="mb-6">
  <h2 class="text-2xl font-bold">Edit Offer</h2>
  <p class="text-gray-500 text-sm">Update promotional offer</p>
</div>

<div class="card max-w-4xl">

<form method="POST" enctype="multipart/form-data" class="space-y-6">

  <!-- Title + Popup + Current Banner -->

  <div class="grid md:grid-cols-2 gap-6">

    <!-- LEFT SIDE -->

    <div class="space-y-4">

      <div>
        <label class="text-sm font-medium">
          Offer Title
        </label>

        <input
          name="title"
          value="<%= offer.title %>"
          class="w-full border p-2 rounded"
          required
        >
      </div>

      <div>
        <label class="text-sm font-medium">
          Popup Banner
        </label>

        <input
          type="file"
          name="popupImage"
          class="w-full border p-2 rounded"
        >

        <p class="text-xs text-gray-500 mt-1">
          Upload new banner to replace current one
        </p>
      </div>

    </div>


    <!-- RIGHT SIDE -->

    <div>

      <label class="text-sm font-medium">
        Current Banner
      </label>

      <% if(offer.popupImage){ %>

        <img
          src="<%= offer.popupImage %>"
          class="w-48 rounded mt-2 shadow"
        >

      <% } else { %>

        <div class="text-gray-400 text-sm mt-2">
          No banner uploaded
        </div>

      <% } %>

    </div>

  </div>


  <!-- Branch Offers -->

  <h3 class="font-semibold border-b pb-2">
    Branch Offers
  </h3>


  <% offer.branchOffers.forEach((b, i) => { %>

  <details class="border rounded p-4" open>

    <summary class="font-semibold cursor-pointer">
      <%= b.branch %> Offer
    </summary>

    <input
      type="hidden"
      name="branchOffers[<%= i %>][branch]"
      value="<%= b.branch %>"
    >


    <div class="grid md:grid-cols-2 gap-6 mt-4">

      <!-- LEFT SIDE -->

      <div class="space-y-3">

        <div>
          <label class="text-sm">Price</label>

          <input
            name="branchOffers[<%= i %>][price]"
            value="<%= b.price %>"
            class="w-full border p-2 rounded"
          >
        </div>

        <div>
          <label class="text-sm">Banner Image</label>

          <input
            type="file"
            name="branchImages"
            class="w-full border p-2 rounded"
          >
        </div>

        <div>
          <label class="text-sm">Offer Details</label>

          <textarea
            name="branchOffers[<%= i %>][details]"
            class="w-full border p-2 rounded"
            rows="2"
          ><%= b.details %></textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">

          <div>
            <label class="text-sm">From</label>

            <input
              type="date"
              name="branchOffers[<%= i %>][validityFrom]"
              value="<%= b.validity?.from?.toISOString().substring(0,10) %>"
              class="w-full border p-2 rounded"
            >
          </div>

          <div>
            <label class="text-sm">To</label>

            <input
              type="date"
              name="branchOffers[<%= i %>][validityTo]"
              value="<%= b.validity?.to?.toISOString().substring(0,10) %>"
              class="w-full border p-2 rounded"
            >
          </div>

        </div>

      </div>


      <!-- RIGHT SIDE -->

      <div>

        <label class="text-sm font-medium">
          Current Banner
        </label>

        <% if(b.bannerImage){ %>

          <img
            src="<%= b.bannerImage %>"
            class="w-48 rounded mt-2 shadow"
          >

        <% } else { %>

          <div class="text-gray-400 text-sm mt-2">
            No banner uploaded
          </div>

        <% } %>

      </div>

    </div>

  </details>

  <% }) %>


  <!-- Buttons -->

  <div class="flex justify-end gap-3 pt-4 border-t">

    <a
      href="/admin/offers"
      class="btn-secondary"
    >
      Cancel
    </a>

    <button class="btn-primary">
      Update Offer
    </button>

  </div>

</form>

</div>
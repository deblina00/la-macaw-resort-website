<!DOCTYPE html>
<html>
<head>

<title>
<%= typeof title !== "undefined" ? title : "Admin Dashboard" %>
</title>

<link rel="stylesheet" href="/css/admin.build.css">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>

body{
font-family: 'Inter', sans-serif;
}

.glass{
background: rgba(255,255,255,0.7);
backdrop-filter: blur(20px);
}

</style>

</head>

<body class="bg-gradient-to-br from-slate-100 to-blue-50">

<div class="flex min-h-screen">

<%- include('sidebar') %>

<div class="flex-1 flex flex-col">

<!-- Topbar -->

<header class="glass sticky top-0 z-10 border-b px-6 py-4 flex justify-between items-center">

<div>

<h1 class="text-xl font-semibold">
<%= typeof title !== "undefined" ? title : "Dashboard" %>
</h1>

<p class="text-sm text-gray-500">
Welcome back, Admin 👋
</p>

</div>

<div class="flex items-center gap-4">


<!-- Profile -->

<div class="flex items-center gap-2">

<div class="w-9 h-9 bg-blue-600 text-white rounded-full flex items-center justify-center font-semibold">
A
</div>

<span class="text-sm font-medium">
Welcome Admin
</span>

</div>

</div>

</header>

<!-- Content -->

<main class="p-6 flex-1">

<%- body %>

</main>

</div>

</div>

</body>
</html>
<h2>Customer Enquiries</h2>

<table class="w-full bg-white">

<tr>
<th>Name</th>
<th>Email</th>
<th>Phone</th>
<th>Type</th>
<th>Message</th>
</tr>

<% enquiries.forEach(e => { %>

<tr>
<td><%= e.name %></td>
<td><%= e.email %></td>
<td><%= e.phone %></td>
<td><%= e.enquiryType %></td>
<td><%= e.message %></td>
</tr>

<% }) %>

</table>
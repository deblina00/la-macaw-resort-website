<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">
      Customer Enquiries
    </h2>

    <p class="text-gray-500 text-sm">
      View and manage customer enquiries and booking requests
    </p>
  </div>

</div>


<!-- Table Card -->

<div class="card overflow-x-auto">

  <table class="w-full text-sm">

    <thead class="bg-gray-100">
      <tr>
        <th class="p-3 text-left">Name</th>
        <th class="p-3 text-left">Contact</th>
        <th class="p-3 text-left">Type</th>
        <th class="p-3 text-left">Message</th>
        <th class="p-3 text-left">Date</th>
      </tr>
    </thead>

    <tbody>

      <% if(enquiries.length === 0){ %>

        <tr>
          <td colspan="5" class="text-center py-6 text-gray-500">
            No enquiries found
          </td>
        </tr>

      <% } %>


      <% enquiries.forEach(e => { %>

       <tr class="border-b hover:bg-gray-50 transition">

         <td class="p-3 font-semibold">
          <%= e.name %>
        </td>


        <td class="p-3">

          <div class="text-sm">
            <p><%= e.email %></p>
            <p class="text-gray-500"><%= e.phone %></p>
          </div>

        </td>


          <td class="p-3">

          <span class="
            px-2 py-1 rounded text-xs font-semibold

            <%= 
              e.enquiryType === 'guest' ? 'bg-emerald-100 text-emerald-700' :
              e.enquiryType === 'event' ? 'bg-purple-100 text-purple-700' :
              e.enquiryType === 'b2b' ? 'bg-gray-100 text-gray-700' :
              'bg-blue-100 text-blue-700'
            %>
          ">
            <%= e.enquiryType %>
          </span>

        </td>


        <td class="max-w-xs truncate text-gray-600">
          <%= e.message %>
        </td>


        <td class="text-sm text-gray-500">
          <%= new Date(e.createdAt).toLocaleDateString() %>
        </td>

      </tr>

      <% }) %>

    </tbody>

  </table>

</div>


<!-- Pagination -->

<div class="flex justify-center mt-6">

  <div class="flex gap-2">

    <% if (currentPage > 1) { %>

      <a
        href="?page=<%= currentPage - 1 %>"
        class="px-3 py-1 border rounded hover:bg-gray-200"
      >
        Previous
      </a>

    <% } %>


    <% for (let i = 1; i <= totalPages; i++) { %>

      <a
        href="?page=<%= i %>"
        class="px-3 py-1 border rounded
        <%= currentPage === i ? 'bg-emerald-600 text-white' : 'hover:bg-gray-200' %>"
      >
        <%= i %>
      </a>

    <% } %>


    <% if (currentPage < totalPages) { %>

      <a
        href="?page=<%= currentPage + 1 %>"
        class="px-3 py-1 border rounded hover:bg-gray-200"
      >
        Next
      </a>

    <% } %>

  </div>

</div>
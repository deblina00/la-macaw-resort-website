<!DOCTYPE html>
<html>
<head>

<title>Admin Login</title>
<link rel="stylesheet" href="/css/admin.build.css">
</head>

<body class="bg-gray-100 flex items-center justify-center h-screen">

<form action="/admin/login" method="POST" class="bg-white p-8 rounded-xl shadow-lg w-96">

<h2 class="text-2xl font-bold text-center mb-6">
La Macaw Admin Login
</h2>

<% if (typeof error !== "undefined") { %>
<div class="bg-red-100 text-red-600 p-2 mb-4 rounded">
<%= error %>
</div>
<% } %>

<input 
type="text"
name="username"
placeholder="Username"
class="w-full border p-3 mb-4 rounded"
required
>

<div class="relative">

<input 
type="password"
name="password"
id="password"
placeholder="Password"
class="w-full border p-3 rounded"
required
>

<button
type="button"
onclick="togglePassword()"
class="absolute right-3 top-3 text-sm text-gray-500"
>
Show
</button>

</div>

<button class="btn-primary w-full mt-5">
Login
</button>

</form>

<script>

function togglePassword() {

  const pass = document.getElementById("password");

  if(pass.type === "password"){
    pass.type = "text";
  } else {
    pass.type = "password";
  }

}

</script>

</body>
</html>
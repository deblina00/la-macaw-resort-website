<!DOCTYPE html>
<html>
<head>

<title>Admin Login</title>
<link rel="stylesheet" href="/css/admin.css">
   <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center h-screen">

<form action="/admin/login" method="POST" class="bg-white p-8 rounded shadow w-96">

<h2 class="text-2xl mb-4 font-bold text-center">Admin Login</h2>

<% if (typeof error !== "undefined") { %>
<div class="bg-red-100 text-red-600 p-2 mb-3 rounded text-sm">
<%= error %>
</div>
<% } %>

<input 
type="text"
name="username"
placeholder="Username"
class="w-full border p-2 mb-3"
required
>

<input 
type="password"
name="password"
placeholder="Password"
class="w-full border p-2 mb-4"
required
>

<button class="bg-blue-600 text-white w-full py-2 rounded">
Login
</button>

</form>

</body>
</html>
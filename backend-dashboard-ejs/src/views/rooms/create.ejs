<div class="mb-6">

  <h2 class="text-2xl font-bold">
    Create Room
  </h2>

  <p class="text-gray-500 text-sm">
    Add a new room to your resort
  </p>

</div>


<div class="card max-w-3xl">

<form method="POST" enctype="multipart/form-data" class="space-y-4">
<div class="grid grid-cols-3 gap-4">
  <div>
    <label class="block text-sm mb-1">Room Title</label>
    <input name="title" class="w-full border p-3 rounded" required>
  </div>

  <div>
    <label class="block text-sm mb-1">Branch</label>

    <select name="branchId" class="w-full border p-3 rounded">

      <% branches.forEach(branch => { %>

      <option value="<%= branch._id %>">
        <%= branch.name %>
      </option>

      <% }) %>

    </select>
  </div>

  <div>
    <label class="block text-sm mb-1">
      Room Gallery
    </label>

    <input
      type="file"
      name="gallery"
      multiple
      class="w-full border p-2 rounded"
    >
  </div>

</div>

  <div class="grid grid-cols-3 gap-4">

    <div>
      <label class="block text-sm mb-1">Price</label>
      <input name="price" class="w-full border p-3 rounded">
    </div>

    <div>
      <label class="block text-sm mb-1">Beds</label>
      <input name="totalBed" class="w-full border p-3 rounded">
    </div>

    <div>
      <label class="block text-sm mb-1">Capacity</label>
      <input name="capacity" class="w-full border p-3 rounded">
    </div>

  </div>


  <div>
    <label class="block text-sm mb-1">
      Amenities (comma separated)
    </label>

    <input
      name="amenities"
      class="w-full border p-3 rounded"
      placeholder="AC, TV, WiFi, Balcony"
    >
  </div>


  <div>
    <label class="block text-sm mb-1">Description</label>

    <textarea
      name="description"
      class="w-full border p-3 rounded h-32"
    ></textarea>
  </div>

  <div class="flex gap-3 pt-4">

    <button class="btn-primary">
      Save Room
    </button>

    <a href="/admin/rooms" class="px-4 py-2 border rounded">
      Cancel
    </a>

  </div>

</form>

</div>
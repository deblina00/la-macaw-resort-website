<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">Rooms</h2>
    <p class="text-gray-500 text-sm">
      Manage resort rooms and pricing
    </p>
  </div>

  <a href="/admin/rooms/create" class="btn-primary">
    + Add Room
  </a>

</div>


<!-- Table Card -->

<div class="card">

  <table class="table">

    <thead>
      <tr>
        <th>Room</th>
        <th>Branch</th>
        <th>Price</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>

    <tbody>

      <% if(rooms.length === 0){ %>

        <tr>
          <td colspan="4" class="text-center text-gray-500 py-6">
            No rooms found
          </td>
        </tr>

      <% } %>

      <% rooms.forEach(room => { %>

      <tr>

        <td class="font-semibold">
          <%= room.title %>
        </td>

        <td>
          <%= room.branchId?.name || "N/A" %>
        </td>

        <td class="text-emerald-600 font-semibold">
          ₹ <%= room.price %>
        </td>

        <td class="text-center space-x-3">

          <a
            href="/admin/rooms/edit/<%= room._id %>"
            class="text-blue-600 hover:underline"
          >
            Edit
          </a>

          <a
            href="/admin/rooms/delete/<%= room._id %>"
            onclick="return confirm('Delete this room?')"
            class="text-red-600 hover:underline"
          >
            Delete
          </a>

        </td>

      </tr>

      <% }) %>

    </tbody>

  </table>

</div>


<!-- Pagination -->

<div class="flex justify-center mt-6">

  <div class="flex gap-2">

    <% if (currentPage > 1) { %>
      <a href="?page=<%= currentPage - 1 %>" class="pagination">
        Previous
      </a>
    <% } %>

    <% for(let i = 1; i <= totalPages; i++) { %>

      <a
        href="?page=<%= i %>"
        class="px-3 py-1 border rounded 
        <%= currentPage === i ? 'bg-emerald-600 text-white' : 'hover:bg-gray-200' %>"
      >
        <%= i %>
      </a>

    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="?page=<%= currentPage + 1 %>" class="pagination">
        Next
      </a>
    <% } %>

  </div>

</div>
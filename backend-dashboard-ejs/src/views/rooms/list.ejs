<div class="flex justify-between items-center mb-6">

  <div>
    <h2 class="text-2xl font-bold">Rooms</h2>
    <p class="text-gray-500 text-sm">
      Manage resort rooms and pricing
    </p>
  </div>

  <a href="/admin/rooms/create" class="btn-primary">
    + Add Room
  </a>

</div>


<!-- Table Card -->

<div class="card overflow-x-auto">

  <table class="w-full text-sm">

    <thead class="bg-gray-100">
      <tr>
        <th class="p-3 text-left">Room</th>
        <th class="p-3 text-left">Image</th>
        <th class="p-3 text-left">Branch</th>
        <th class="p-3 text-left">Price</th>
        <th class="p-3 text-center">Actions</th>
      </tr>
    </thead>

    <tbody>

      <% if(rooms.length === 0){ %>

        <tr>
          <td colspan="5" class="text-center text-gray-500 py-8">
            No rooms found
          </td>
        </tr>

      <% } %>

      <% rooms.forEach(room => { %>

      <tr class="border-b hover:bg-gray-50 transition">

        <!-- Room Title -->

        <td class="p-3 font-semibold">
          <%= room.title %>
        </td>

        <!-- Image -->

        <td class="p-3">

          <% if(room.gallery){ %>

            <img
              src="<%= room.gallery %>"
              alt="room"
              class="w-16 h-12 object-cover rounded-lg shadow"
            >

          <% } else { %>

            <span class="text-gray-400 text-xs">
              No Image
            </span>

          <% } %>

        </td>

        <!-- Branch -->

        <td class="p-3">
          <%= room.branchId?.name || "N/A" %>
        </td>

        <!-- Price -->

        <td class="p-3 text-emerald-600 font-semibold">
          ₹ <%= room.price %>
        </td>

        <!-- Actions -->

        <td class="p-3 text-center">

          <div class="flex justify-center gap-2">

            <!-- Edit -->

            <a
              href="/admin/rooms/edit/<%= room._id %>"
              class="px-3 py-1 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition text-xs"
            >
              ✏ Edit
            </a>
            
            <!-- Delete -->

            <a
              href="/admin/rooms/delete/<%= room._id %>"
              onclick="return confirm('Delete this room?')"
              class="px-3 py-1 bg-red-500 text-white rounded-lg hover:bg-red-600 transition text-xs"
            >
              🗑 Delete
            </a>

          </div>

        </td>

      </tr>

      <% }) %>

    </tbody>

  </table>

</div>

<!-- Pagination -->

<div class="flex justify-center mt-6">

  <div class="flex gap-2">

    <% if (currentPage > 1) { %>
      <a href="?page=<%= currentPage - 1 %>" class="pagination">
        Previous
      </a>
    <% } %>

    <% for(let i = 1; i <= totalPages; i++) { %>

      <a
        href="?page=<%= i %>"
        class="px-3 py-1 border rounded 
        <%= currentPage === i ? 'bg-emerald-600 text-white' : 'hover:bg-gray-200' %>"
      >
        <%= i %>
      </a>

    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="?page=<%= currentPage + 1 %>" class="pagination">
        Next
      </a>
    <% } %>

  </div>

</div>